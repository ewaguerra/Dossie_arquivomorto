{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "node scripts/generate-surface-links.mjs",
  "installCommand": "echo skip",
  "framework": null,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/arquivista/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/app/vendor/:path*",
      "destination": "/vendor/app/vendor/:path*"
    },
    {
      "source": "/app/:path*",
      "destination": "/vendor/app/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/vendor/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/app/vendor/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
